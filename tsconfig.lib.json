{
  "extends": "./tsconfig.json",
  "include": ["src/core/**/*.ts", "src/core/**/*.tsx"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx"],
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "stripInternal": true,
    "rootDir": "src/core",
    "outDir": "dist"
  }
}
